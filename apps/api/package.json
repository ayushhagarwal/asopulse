{
  "name": "@asopulse/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.json",
    "lint": "biome check src",
    "test": "vitest run src",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false"
  },
  "dependencies": {
    "@asopulse/core": "workspace:*",
    "@asopulse/db": "workspace:*",
    "@asopulse/domain": "workspace:*",
    "@asopulse/providers": "workspace:*",
    "@fastify/cors": "^11.3.0",
    "@fastify/cookie": "^11.1.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.8.1",
    "@fastify/swagger-ui": "^6.1.0",
    "argon2": "^0.45.0",
    "bullmq": "^5.80.9",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.10.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "vitest": "^4.1.10"
  }
}
